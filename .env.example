PYTHONDONTWRITEBYTECODE=1

# LLM provider: ollama | anthropic | openai | groq | vllm
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_BASE_URL=http://localhost:8000/v1
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.95
LLM_MAX_CONCURRENCY=8
PARALLEL_EXCHANGE_JOBS=1

# Simulation parameters
TOPIC=immigration policy
N_AGENTS=12
N_ITERATIONS=50
MIN_TURNS=2
MAX_TURNS=5
RANDOM_SEED=42

# Memory condition: no_kg | general_only | tom_only | full_kg
MEMORY_CONDITION=no_kg

# FSRS clock advance per iteration (hours). 24h makes decay fire meaningfully.
CLOCK_ADVANCE_HOURS=24

# Output paths (created automatically if missing)
OUTPUT_DIR=data/run_01
DB_PATH=data/run_01/simulation.db

# API keys (only needed for the respective provider)
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
